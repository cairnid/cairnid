CAIRN_ENV=development
CAIRN_API_BIND=0.0.0.0:8080
# Production origins must be HTTPS and must not include a path, query, fragment, or credentials.
# Development may use HTTP only for localhost, 127.0.0.1, or [::1].
CAIRN_ISSUER=http://localhost:8080
CAIRN_PUBLIC_WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://cairn:cairn@localhost:5432/cairn_identity
RUST_LOG=cairn_api=info,cairn_oidc=info,tower_http=info

# Required when CAIRN_ENV=production. The first-admin bootstrap request must
# submit this operator-held setup secret.
# CAIRN_BOOTSTRAP_SETUP_SECRET=replace-with-random-setup-secret

# Required for database-backed signing-key generation, rotation,
# encrypted TOTP MFA secrets, and production lifecycle email outbox delivery tokens.
# Generate a production value with:
#   cairn-api signing-key generate-kek
CAIRN_KEY_ENCRYPTION_KEY=replace-with-generate-kek-output
# Only set these during KEK re-encryption maintenance:
# CAIRN_OLD_KEY_ENCRYPTION_KEY=<old value>
# CAIRN_NEW_KEY_ENCRYPTION_KEY=<new value>

# Lifecycle email delivery.
# development: stdout writes rendered payloads to stderr for local inspection.
# production: command invokes an executable with JSON on stdin and no shell.
# Validate command-provider credentials with:
#   cairn-api email-outbox smoke-provider ops@example.com
CAIRN_EMAIL_PROVIDER=stdout
# CAIRN_EMAIL_PROVIDER=command
# CAIRN_EMAIL_COMMAND_PATH=/app/send-email
CAIRN_EMAIL_BATCH_SIZE=10
CAIRN_EMAIL_MAX_ATTEMPTS=5
CAIRN_EMAIL_RETRY_SECONDS=300
CAIRN_EMAIL_SENDING_TIMEOUT_SECONDS=900

# Audit retention and bounded admin export.
# Purge applies to CAIRN_DEFAULT_ORG_SLUG when an operator runs:
#   cairn-api audit purge-expired
CAIRN_AUDIT_RETENTION_DAYS=365
CAIRN_AUDIT_PURGE_BATCH_SIZE=1000
CAIRN_AUDIT_EXPORT_MAX_ROWS=10000

# Optional SCIM provisioning bearer-token hashes.
# Set one SHA-256 hex hash normally. During token rotation, set up to four
# comma-separated hashes for the old and new raw tokens, then remove retired hashes.
# CAIRN_SCIM_BEARER_TOKEN_SHA256=<64-char lowercase hex sha256>

# Public-beta release evidence capture.
# Run before collecting artifacts; it prints required variable names, not values:
#   cairnid evidence plan
# Then initialize the access-controlled evidence directory:
#   cairnid evidence init ./release-evidence
# During capture, summarize remaining artifact work with:
#   cairnid evidence status ./release-evidence
# Before public beta, run the final local release gate:
#   cairnid evidence check ./release-evidence
#
# Deployed smoke commands can use CAIRN_ISSUER/CAIRN_PUBLIC_WEB_ORIGIN or these
# explicit production-like origins:
# CAIRN_BROWSER_ORIGIN_SMOKE_BASE_URL=https://id.example.com
# CAIRN_BROWSER_ORIGIN_SMOKE_HOSTILE_ORIGIN=https://browser-origin-smoke.invalid
# CAIRN_SECURITY_HEADERS_API_BASE_URL=https://id.example.com
# CAIRN_SECURITY_HEADERS_WEB_BASE_URL=https://app.example.com
#
# For public-beta SCIM release evidence, provide raw smoke tokens for the
# deployed connector secret, a still-accepted rotation token, and a retired
# or invalid token that must return 401.
# CAIRN_SCIM_SMOKE_BASE_URL=https://id.example.com
# CAIRN_SCIM_BEARER_TOKEN=<raw token>
# CAIRN_SCIM_SECONDARY_BEARER_TOKEN=<old-or-new token during rotation>
# CAIRN_SCIM_REJECTED_BEARER_TOKEN=<retired-or-invalid token>

# Optional OpenID Foundation conformance static-client setup.
# Keep generated suite JSON out of source control because it contains client secrets.
# Check readiness with:
#   cairn-api operations preflight
# Before OIDF execution, validate deployed discovery and JWKS with:
#   cairn-api operations oidc-metadata-smoke
# CAIRN_OIDC_METADATA_SMOKE_ISSUER=https://id.example.com
# CAIRN_CONFORMANCE_ALIAS=cairn-basic-op
# CAIRN_CONFORMANCE_SUITE_BASE_URL=https://www.certification.openid.net/
# CAIRN_CONFORMANCE_CLIENT_ID=<primary client id>
# CAIRN_CONFORMANCE_CLIENT_SECRET=<primary client secret>
# CAIRN_CONFORMANCE_CLIENT2_ID=<secondary client id>
# CAIRN_CONFORMANCE_CLIENT2_SECRET=<secondary client secret>

# Emergency operator-only admin recovery.
# Set only for the one command invocation:
#   cairn-api admin break-glass-owner ops@example.com
# CAIRN_BREAK_GLASS_CONFIRM=grant-admin-owner

# Legacy static signing material can be used as bootstrap/import fallback.
# CAIRN_SIGNING_KEY_ID=local-dev-key
# CAIRN_SIGNING_PRIVATE_KEY_PEM=<escaped private signing key PEM>
# CAIRN_SIGNING_PUBLIC_JWK={"kty":"RSA","kid":"local-dev-key","use":"sig","alg":"RS256","n":"...","e":"AQAB"}
