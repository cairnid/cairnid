{
  "name": "@cairn/identity-web",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --bun vite --host 0.0.0.0",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview --host 0.0.0.0",
    "check": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json",
    "test": "bun --bun vitest run",
    "test:e2e": "bun --bun vite build && bun --bun playwright test"
  },
  "dependencies": {
    "@lucide/svelte": "^1.22.0",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.68.0",
    "svelte": "^5.56.4",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
