{
  "name": "cairnid",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cairnid/cairnid.git"
  },
  "bugs": {
    "url": "https://github.com/cairnid/cairnid/issues"
  },
  "homepage": "https://github.com/cairnid/cairnid#readme",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "check": "bun run --cwd apps/web check",
    "check:public-surface": "bun infra/scripts/check-public-surface.ts",
    "check:web-api-contract": "bun infra/scripts/check-web-api-contract.ts",
    "docs:site": "bun infra/scripts/generate-site-docs.ts",
    "test": "bun run --cwd apps/web test",
    "test:e2e": "bun run --cwd apps/web test:e2e",
    "audit": "bun audit"
  },
  "overrides": {
    "cookie": "0.7.2"
  },
  "workspaces": [
    "apps/web"
  ]
}
